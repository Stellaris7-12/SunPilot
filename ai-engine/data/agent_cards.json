[
  {
    "agent_id": "classifier_agent",
    "name": "Classifier Agent / 分类与优先级判定",
    "description": "分析工单内容，识别业务场景、工单类型、优先级和处理路径",
    "version": "1.0.0",
    "skills": [
      {
        "id": "scenario_classification",
        "name": "业务场景分类",
        "description": "识别工单业务场景：优惠券补发、资料修改、交易争议等",
        "examples": ["识别优惠券补发请求", "识别地址修改请求", "识别交易争议请求"]
      }
    ],
    "input_schema": {
      "type": "object",
      "properties": {
        "ticket_content": {"type": "string", "description": "工单原文内容"},
        "workflow_config": {"type": "object", "description": "轻量工作流配置"}
      },
      "required": ["ticket_content"]
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "type": {"type": "string", "enum": ["COUPON_REISSUE", "CUSTOMER_ADDRESS_UPDATE", "TRANSACTION_DISPUTE", "UNKNOWN"]},
        "label": {"type": "string"},
        "confidence": {"type": "number"},
        "workflow_name": {"type": "string"},
        "reason": {"type": "string"}
      }
    },
    "requires_human_review": false,
    "max_risk_level": "high",
    "timeout_seconds": 30,
    "retry_policy": "no_retry",
    "dependencies": []
  },
  {
    "agent_id": "intake_agent",
    "name": "Intake Agent / 接单与信息提取",
    "description": "接收工单或通话文本，并根据业务场景抽取结构化字段",
    "version": "1.0.0",
    "skills": [
      {
        "id": "field_extraction",
        "name": "字段抽取",
        "description": "根据场景配置抽取对应的结构化业务字段",
        "examples": ["抽取优惠券补发所需字段", "抽取资料修改所需字段", "抽取交易核查所需字段"]
      }
    ],
    "input_schema": {
      "type": "object",
      "properties": {
        "ticket_content": {"type": "string"},
        "intent_type": {"type": "string"},
        "intent_label": {"type": "string"},
        "workflow_config": {"type": "object"}
      },
      "required": ["ticket_content", "intent_type"]
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": {"type": "string"},
              "name": {"type": "string"},
              "value": {"type": "string"}
            }
          }
        }
      }
    },
    "requires_human_review": false,
    "max_risk_level": "high",
    "timeout_seconds": 30,
    "retry_policy": "no_retry",
    "dependencies": ["classifier_agent"]
  },
  {
    "agent_id": "escalation_agent",
    "name": "Escalation Agent / 升级与兜底",
    "description": "校验字段完整性，判断风险、人工确认、暂停待补充和升级人工",
    "version": "1.0.0",
    "skills": [
      {
        "id": "routing_guardrail",
        "name": "升级与兜底判断",
        "description": "识别字段缺失、合规敏感、工具失败和需要人工介入的场景",
        "examples": ["信息不足暂停", "中风险人工确认", "高风险直接升级"]
      },
      {
        "id": "completeness_check",
        "name": "完整性校验",
        "description": "根据 workflow_config 检查必填字段是否完整",
        "examples": ["检查客户号是否缺失", "检查交易金额是否完整"]
      }
    ],
    "input_schema": {
      "type": "object",
      "properties": {
        "ticket": {"type": "object"},
        "intent": {"type": "object"},
        "fields": {"type": "array"},
        "tool_result": {"type": "object"},
        "workflow_config": {"type": "object"}
      },
      "required": ["ticket", "intent", "fields"]
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "checks": {"type": "array"},
        "risk_level": {"type": "string"},
        "risk_decision": {"type": "string"},
        "can_auto_proceed": {"type": "boolean"},
        "missing_fields": {"type": "array"},
        "needs_more_info": {"type": "boolean"}
      }
    },
    "requires_human_review": true,
    "max_risk_level": "high",
    "timeout_seconds": 30,
    "retry_policy": "no_retry",
    "dependencies": ["classifier_agent", "intake_agent"]
  },
  {
    "agent_id": "resolution_agent",
    "name": "Resolution Agent / 解决方案与执行",
    "description": "根据分类和字段选择业务工具，生成调用参数，并交由执行器完成业务动作",
    "version": "1.0.0",
    "skills": [
      {
        "id": "tool_selection",
        "name": "工具选择与执行准备",
        "description": "从工具注册表中匹配正确业务工具，并生成调用参数",
        "examples": ["调用coupon.reissue补发优惠券", "调用customer.update-address修改地址", "调用transaction.query查询交易"]
      }
    ],
    "input_schema": {
      "type": "object",
      "properties": {
        "intent": {"type": "object"},
        "fields": {"type": "array"},
        "available_tools": {"type": "string"},
        "workflow_config": {"type": "object"}
      },
      "required": ["intent", "fields", "available_tools"]
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "tool_name": {"type": "string"},
        "tool_params": {"type": "object"},
        "skip": {"type": "boolean"},
        "skip_reason": {"type": "string"}
      }
    },
    "requires_human_review": false,
    "max_risk_level": "medium",
    "timeout_seconds": 30,
    "retry_policy": "retry_on_error",
    "dependencies": ["classifier_agent", "intake_agent", "escalation_agent"]
  },
  {
    "agent_id": "notification_agent",
    "name": "Notification Agent / 通知与回访",
    "description": "根据全流程处理结果生成客户回单、内部通知和后续跟进提示",
    "version": "1.0.0",
    "skills": [
      {
        "id": "reply_generation",
        "name": "回单与通知生成",
        "description": "生成专业、简洁、可解释的客户回单和状态说明",
        "examples": ["生成优惠券补发成功的话术", "生成地址修改完成的话术", "生成交易争议转人工的话术"]
      }
    ],
    "input_schema": {
      "type": "object",
      "properties": {
        "intent": {"type": "object"},
        "fields": {"type": "array"},
        "tool_result": {"type": "object"},
        "verify_result": {"type": "object"},
        "workflow_config": {"type": "object"}
      },
      "required": ["intent", "fields"]
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "reply_draft": {"type": "string"}
      }
    },
    "requires_human_review": true,
    "max_risk_level": "high",
    "timeout_seconds": 30,
    "retry_policy": "no_retry",
    "dependencies": ["classifier_agent", "intake_agent", "escalation_agent", "resolution_agent"]
  }
]
