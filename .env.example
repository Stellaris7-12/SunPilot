# LLM
LLM_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=sk-your-api-key-here
LLM_MODEL=deepseek-chat

# Database backend: mysql or tdsql
# Local development uses root with the password from MYSQL_ROOT_PASSWORD.
# Demo database: ticket_agent
# Smoke test database: ticket_agent_test
DB_BACKEND=mysql
DATABASE_URL=mysql+asyncmy://root:${MYSQL_ROOT_PASSWORD}@127.0.0.1:3306/ticket_agent?charset=utf8mb4
DB_POOL_SIZE=5
DB_TIMEOUT_SECONDS=30
DB_SSL_ENABLED=false

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*
